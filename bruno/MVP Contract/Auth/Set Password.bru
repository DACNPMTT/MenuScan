meta {
  name: Set Password
  type: http
  seq: 7
}

post {
  url: {{base_url}}{{api_prefix}}/auth/set-password
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{access_token}}
  Content-Type: application/json
}

body:json {
  {
    "password": "secure_password_123"
  }
}

vars:pre-request {
  access_token:
  api_prefix: /api/v1
  base_url: http://localhost:8000
}
