meta {
  name: Confirm Menu
  type: http
  seq: 4
}

post {
  url: {{base_url}}{{api_prefix}}/menus/{{menu_id}}/confirm
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{access_token}}
}

tests {
  test("confirms draft menu", function () {
    expect(res.status).to.equal(200);
    expect(res.body.success).to.equal(true);
    expect(res.body.data.status).to.equal("CONFIRMED");
    expect(res.body.data.is_saved).to.equal(true);
  });
}
