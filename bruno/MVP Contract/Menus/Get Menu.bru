meta {
  name: Get Menu
  type: http
  seq: 2
}

get {
  url: {{base_url}}{{api_prefix}}/menus/{{menu_id}}
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{access_token}}
}

tests {
  test("returns menu detail with items", function () {
    expect(res.status).to.equal(200);
    expect(res.body.success).to.equal(true);
    expect(res.body.data.id).to.equal(bru.getEnvVar("menu_id"));
    expect(res.body.data.food_items).to.be.an("array");
  });
}
