                <UserObject label="" mermaidData="{&quot;data&quot;: &quot;\nflowchart TD\n    subgraph U[\&quot;Người dùng (guest hoặc đã đăng nhập)\&quot;]\n        A1([Mở ứng dụng]) --&gt; A2[Chọn chức năng Scan menu]\n        A2 --&gt; A3[Chọn ảnh/PDF&lt;br/&gt;hoặc chụp bằng camera]\n        A3 --&gt; A4[Chọn ngôn ngữ đích]\n        A9[Xem danh sách món:&lt;br/&gt;tên gốc, tên đã dịch,&lt;br/&gt;mô tả, giá, độ tin cậy]\n        A10[Sửa/thêm/xóa món nếu cần]\n        A11[Xác nhận lưu menu]\n        A12([Kết thúc])\n    end\n\n    subgraph S[\&quot;Hệ thống MenuScan\&quot;]\n        B1{File hợp lệ?&lt;br/&gt;≤10MB/file, tổng ≤40MB,&lt;br/&gt;≤8 trang}\n        B2[Báo lỗi file không hợp lệ]\n        B3{Đủ khoảng cách&lt;br/&gt;giữa 2 lần scan?&lt;br/&gt;bảng ai_throttle}\n        B4[429 RATE_LIMITED&lt;br/&gt;báo thử lại sau N giây]\n        B5[Lưu file gốc vào Object Storage&lt;br/&gt;Tạo scan_session = PENDING]\n        B6[/202 Accepted — trả scan_id NGAY/]\n        B7[Chạy nền: ScanPipeline]\n        B8[stage OCR&lt;br/&gt;tiền xử lý + Google Vision]\n        B9{OCR thành công?}\n        B10[status = FAILED&lt;br/&gt;kèm error_code]\n        B11[stage ANALYZING&lt;br/&gt;Gemini trích danh sách món]\n        B12[stage TRANSLATING&lt;br/&gt;dịch tên và mô tả]\n        B13[stage FINALIZING&lt;br/&gt;lưu menus + food_items]\n        B14[status = COMPLETED]\n        B15[/Frontend poll GET /scans/id&lt;br/&gt;tới khi COMPLETED hoặc FAILED/]\n        B16[Trả kết quả + signed URL file gốc]\n    end\n\n    A4 --&gt; B1\n    B1 -- Không --&gt; B2 --&gt; A3\n    B1 -- Có --&gt; B3\n    B3 -- Không --&gt; B4 --&gt; A3\n    B3 -- Có --&gt; B5 --&gt; B6 --&gt; B7 --&gt; B8 --&gt; B9\n    B9 -- Không --&gt; B10 --&gt; B15\n    B9 -- Có --&gt; B11 --&gt; B12 --&gt; B13 --&gt; B14 --&gt; B15\n    B15 --&gt; B16 --&gt; A9 --&gt; A10 --&gt; A11 --&gt; A12\n\n    style B6 fill:#dbeafe,stroke:#2563eb\n    style B10 fill:#fee2e2,stroke:#dc2626\n    style B2 fill:#fee2e2,stroke:#dc2626\n    style B4 fill:#fef9c3,stroke:#ca8a04\n    style B14 fill:#dcfce7,stroke:#16a34a\n&quot;}" id="2">
