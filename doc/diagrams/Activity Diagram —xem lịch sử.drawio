<mxfile host="app.diagrams.net">
    <diagram id="ActivityDiagramxemlchsdr" name="Activity Diagram —xem lịch sử">
        <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <UserObject label="" mermaidData="{&quot;data&quot;: &quot;\nflowchart TD\n    subgraph U[\&quot;Người dùng\&quot;]\n        A1([Mở ứng dụng]) --&gt; A2[Chọn xem lịch sử]\n        A3[Đăng nhập]\n        A6[Xem danh sách menu đã lưu&lt;br/&gt;hoặc lịch sử scan]\n        A7[Chọn một mục]\n        A9[Xem lại kết quả:&lt;br/&gt;file gốc + danh sách món]\n        A10[Xóa mục không cần nữa]\n        A11([Kết thúc])\n    end\n\n    subgraph S[\&quot;Hệ thống MenuScan\&quot;]\n        B1{User đã đăng nhập?}\n        B2[Yêu cầu đăng nhập&lt;br/&gt;Guest KHÔNG có lịch sử]\n        B3[GET /api/v1/menus — menu đã lưu&lt;br/&gt;GET /api/v1/scans — phiên scan&lt;br/&gt;GET /api/v1/bills — hóa đơn]\n        B4{Có dữ liệu?}\n        B5[Hiển thị 'Chưa có lịch sử']\n        B6[Hiển thị danh sách, mới nhất trước]\n        B7[GET /api/v1/menus/id&lt;br/&gt;hoặc GET /api/v1/scans/id/result]\n        B8{Mục còn tồn tại&lt;br/&gt;và thuộc user này?}\n        B9[404 — không lộ sự tồn tại&lt;br/&gt;của dữ liệu người khác]\n        B10[Trả chi tiết + signed URL file gốc]\n        B11[DELETE /api/v1/menus/id&lt;br/&gt;soft-delete menu và scan liên quan]\n    end\n\n    A2 --&gt; B1\n    B1 -- Chưa --&gt; B2 --&gt; A3 --&gt; B1\n    B1 -- Rồi --&gt; B3 --&gt; B4\n    B4 -- Không --&gt; B5 --&gt; A11\n    B4 -- Có --&gt; B6 --&gt; A6 --&gt; A7 --&gt; B7 --&gt; B8\n    B8 -- Không --&gt; B9 --&gt; A6\n    B8 -- Có --&gt; B10 --&gt; A9 --&gt; A10 --&gt; B11 --&gt; A11\n\n    style B2 fill:#fef9c3,stroke:#ca8a04\n    style B5 fill:#fef9c3,stroke:#ca8a04\n    style B9 fill:#fee2e2,stroke:#dc2626\n    style B6 fill:#dcfce7,stroke:#16a34a\n&quot;}" id="2">
