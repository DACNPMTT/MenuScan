                <UserObject label="sequenceDiagram&#xa;    actor User as Người dùng&#xa;    participant FE as Frontend&#xa;    participant API as Backend API&#xa;    participant ID as Identity Module&#xa;    participant DB as Database&#xa;&#xa;&#xa;    rect rgb(239,246,255)&#xa;        User-&gt;&gt;FE: Nhập email&#xa;        FE-&gt;&gt;API: POST /api/v1/auth/magic-links&#xa;        API-&gt;&gt;ID: request_magic_link(email)&#xa;&#xa;&#xa;        ID-&gt;&gt;DB: Kiểm tra user theo email&#xa;        DB--&gt;&gt;ID: user hoặc null&#xa;&#xa;&#xa;        ID-&gt;&gt;ID: Sinh magic link token&#xa;        ID--&gt;&gt;API: Magic link created&#xa;        API--&gt;&gt;FE: 202 Accepted&#xa;&#xa;&#xa;        FE--&gt;&gt;User: Kiểm tra email&#xa;    end&#xa;&#xa;&#xa;    rect rgb(248,250,252)&#xa;        User-&gt;&gt;FE: Click Magic Link&#xa;        FE-&gt;&gt;API: POST /api/v1/auth/magic-links/verify&#xa;        API-&gt;&gt;ID: verify_magic_link(token)&#xa;&#xa;&#xa;        ID-&gt;&gt;DB: Tìm token&#xa;        DB--&gt;&gt;ID: token_record&#xa;    end&#xa;&#xa;&#xa;    alt Token không hợp lệ&#xa;        rect rgb(254,226,226)&#xa;            ID--&gt;&gt;API: 400 INVALID_MAGIC_LINK&#xa;            API--&gt;&gt;FE: Liên kết không hợp lệ&#xa;            FE--&gt;&gt;User: Hiển thị lỗi&#xa;        end&#xa;&#xa;&#xa;    else Token hết hạn&#xa;        rect rgb(254,226,226)&#xa;            ID--&gt;&gt;API: 401 MAGIC_LINK_EXPIRED&#xa;            API--&gt;&gt;FE: Liên kết hết hạn&#xa;            FE--&gt;&gt;User: Hiển thị lỗi&#xa;        end&#xa;&#xa;&#xa;    else Đăng nhập thành công&#xa;        rect rgb(220,252,231)&#xa;            ID-&gt;&gt;DB: User tồn tại?&#xa;            alt Chưa tồn tại&#xa;                ID-&gt;&gt;DB: Tạo User mới&#xa;            end&#xa;&#xa;&#xa;            ID-&gt;&gt;DB: Mark token consumed&#xa;            ID-&gt;&gt;ID: Tạo access_token&#xa;            ID-&gt;&gt;ID: Tạo refresh_token&#xa;            ID-&gt;&gt;DB: Lưu session&#xa;&#xa;&#xa;            DB--&gt;&gt;ID: Lưu thành công&#xa;&#xa;&#xa;            ID--&gt;&gt;API: access_token + refresh_token&#xa;            API--&gt;&gt;FE: 200 OK&#xa;            FE--&gt;&gt;User: Đăng nhập thành công&#xa;        end&#xa;    end" mermaidData="{&#xa;  &quot;data&quot;: &quot;sequenceDiagram\n    actor User as Người dùng\n    participant FE as Frontend\n    participant API as Backend API\n    participant ID as Identity Module\n    participant DB as Database\n\n    rect rgb(239,246,255)\n        User-&gt;&gt;FE: Nhập email\n        FE-&gt;&gt;API: POST /api/v1/auth/magic-links\n        API-&gt;&gt;ID: request_magic_link(email)\n\n        ID-&gt;&gt;DB: Kiểm tra user theo email\n        DB--&gt;&gt;ID: user hoặc null\n\n        ID-&gt;&gt;ID: Sinh magic link token\n        ID--&gt;&gt;API: Magic link created\n        API--&gt;&gt;FE: 202 Accepted\n\n        FE--&gt;&gt;User: Kiểm tra email\n    end\n\n    rect rgb(248,250,252)\n        User-&gt;&gt;FE: Click Magic Link\n        FE-&gt;&gt;API: POST /api/v1/auth/magic-links/verify\n        API-&gt;&gt;ID: verify_magic_link(token)\n\n        ID-&gt;&gt;DB: Tìm token\n        DB--&gt;&gt;ID: token_record\n    end\n\n    alt Token không hợp lệ\n        rect rgb(254,226,226)\n            ID--&gt;&gt;API: 400 INVALID_MAGIC_LINK\n            API--&gt;&gt;FE: Liên kết không hợp lệ\n            FE--&gt;&gt;User: Hiển thị lỗi\n        end\n\n    else Token hết hạn\n        rect rgb(254,226,226)\n            ID--&gt;&gt;API: 401 MAGIC_LINK_EXPIRED\n            API--&gt;&gt;FE: Liên kết hết hạn\n            FE--&gt;&gt;User: Hiển thị lỗi\n        end\n\n    else Đăng nhập thành công\n        rect rgb(220,252,231)\n            ID-&gt;&gt;DB: User tồn tại?\n            alt Chưa tồn tại\n                ID-&gt;&gt;DB: Tạo User mới\n            end\n\n            ID-&gt;&gt;DB: Mark token consumed\n            ID-&gt;&gt;ID: Tạo access_token\n            ID-&gt;&gt;ID: Tạo refresh_token\n            ID-&gt;&gt;DB: Lưu session\n\n            DB--&gt;&gt;ID: Lưu thành công\n\n            ID--&gt;&gt;API: access_token + refresh_token\n            API--&gt;&gt;FE: 200 OK\n            FE--&gt;&gt;User: Đăng nhập thành công\n        end\n    end&quot;&#xa;}" id="2">
