<mxfile host="app.diagrams.net">
    <diagram id="ActivityDiagramtmkimdraw" name="Activity Diagram — tìm kiếm">
        <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <UserObject label="" mermaidData="{&quot;data&quot;: &quot;\nflowchart TD\n    subgraph U[\&quot;Người dùng (đã đăng nhập)\&quot;]\n        A1([Mở ứng dụng]) --&gt; A2[Mở danh sách menu đã lưu]\n        A2 --&gt; A3[Chọn MỘT menu để xem chi tiết]\n        A3 --&gt; A4[Nhập từ khóa vào thanh lọc&lt;br/&gt;MenuFilterBar]\n        A4b[Hoặc lọc theo nhóm món / khoảng giá]\n        A7[Xem danh sách món khớp]\n        A8[Chọn một món để xem chi tiết]\n        A9([Kết thúc])\n    end\n\n    subgraph S[\&quot;Hệ thống MenuScan\&quot;]\n        B1[GET /api/v1/menus&lt;br/&gt;danh sách menu của user]\n        B2[GET /api/v1/menus/id&lt;br/&gt;chi tiết menu]\n        B3[Debounce từ khóa phía client]\n        B4[GET /api/v1/menus/id/items&lt;br/&gt;?search=...&amp;page=...]\n        B5[Lọc food_items TRONG menu đó&lt;br/&gt;theo tên / nhóm / giá]\n        B6{Có món nào khớp?}\n        B7[Hiển thị 'Không tìm thấy món phù hợp']\n        B8[Trả danh sách món + phân trang]\n        B9[Hiển thị chi tiết món:&lt;br/&gt;tên đã dịch, mô tả, giá,&lt;br/&gt;tag nguyên liệu, mức vị,&lt;br/&gt;cảnh báo dị ứng, verdict gợi ý]\n    end\n\n    A2 --&gt; B1 --&gt; B2\n    A3 --&gt; B2\n    A4 --&gt; B3 --&gt; B4 --&gt; B5 --&gt; B6\n    A4b --&gt; B4\n    B6 -- Không --&gt; B7 --&gt; A4\n    B6 -- Có --&gt; B8 --&gt; A7 --&gt; A8 --&gt; B9 --&gt; A9\n\n    N[\&quot;PHẠM VI: đây là LỌC MÓN BÊN TRONG MỘT MENU.&lt;br/&gt;MenuScan KHÔNG có tìm kiếm toàn cục —&lt;br/&gt;không tìm xuyên nhiều menu, không tìm trên&lt;br/&gt;kho dữ liệu món chung.\&quot;]\n    N -.- B5\n\n    style B7 fill:#fef9c3,stroke:#ca8a04\n    style B5 fill:#dbeafe,stroke:#2563eb\n    style N fill:#fee2e2,stroke:#dc2626\n&quot;}" id="2">
                    <mxCell style="shape=image;noLabel=1;verticalAlign=top;imageAspect=1;image=data:image/svg+xml,;" vertex="1" parent="1">
                        <mxGeometry x="20" y="20" width="1600.0" height="1545.1" as="geometry"/>
                    </mxCell>
                </UserObject>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>
