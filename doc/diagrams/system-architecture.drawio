        <mxCell id="note_rag" value="KHONG co Vector DB / RAG engine. Goi y mon duoc cham bang luat tren preference cua participant trong dining session, khong phai retrieval tren embedding. Advisor chat grounding truc tiep tren danh sach mon cua chinh menu do." style="shape=note;whiteSpace=wrap;html=1;size=14;fontSize=11;align=left;spacingLeft=6;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
