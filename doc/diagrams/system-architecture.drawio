        <mxCell id="ext_gemini" value="Gemini&#10;3 config tach biet:&#10;llm (scan/parser) · chat_llm (advisor)&#10;enrich_llm (enrichment)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=11;" vertex="1" parent="lane_ext">
