        </mxCell>

        <mxCell id="lane_fe" value="Frontend" style="swimlane;horizontal=0;startSize=26;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;html=1;" vertex="1" parent="1">
