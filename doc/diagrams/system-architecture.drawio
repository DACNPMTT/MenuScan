        <mxCell id="note_redis" value="KHONG dung Redis. docker-compose.yml co container Redis nhung khong dong code nao dung no. Anti-spam throttle chay bang mot upsert atomic vao bang ai_throttle trong Postgres (src/core/rate_limit.py) — cung co che voi cooldown magic-link." style="shape=note;whiteSpace=wrap;html=1;size=14;fontSize=11;align=left;spacingLeft=6;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
