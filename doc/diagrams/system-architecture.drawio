        </mxCell>
        <mxCell id="a_guest" value="Guest / Participant&#10;(KHONG can tai khoan)" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;fontSize=11;" vertex="1" parent="lane_actor">
