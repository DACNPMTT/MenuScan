<mxfile host="app.diagrams.net">
  <diagram id="menuscan-system-architecture" name="MenuScan System Architecture">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1650" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="MenuScan — System Architecture&#10;FastAPI modular monolith + React SPA. PostgreSQL la datastore runtime duy nhat." style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="20" width="880" height="52" as="geometry"/>
        </mxCell>

        <mxCell id="lane_actor" value="Nguoi dung" style="swimlane;horizontal=0;startSize=26;fillColor=#f5f5f5;strokeColor=#999999;fontStyle=1;html=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="200" height="300" as="geometry"/>
        </mxCell>
