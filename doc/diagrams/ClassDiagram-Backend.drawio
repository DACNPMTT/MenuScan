        <mxCell id="co1_m0" value="Base, SessionLocal, get_db()" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=6;overflow=hidden;rotatable=0;whiteSpace=wrap;html=1;fontSize=10;fontFamily=Courier New;" vertex="1" parent="co1"><mxGeometry y="40" width="300" height="16" as="geometry"/></mxCell>
        <mxCell id="co2" value="core.rate_limit" style="swimlane;fontStyle=1;childLayout=stackLayout;horizontal=1;startSize=26;horizontalStack=0;resizeParent=0;resizeParentMax=0;html=1;whiteSpace=wrap;fontSize=12;swimlaneFillColor=#ffffff;fillColor=#e8e8e8;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="760" y="1440" width="300" height="94" as="geometry"/></mxCell>
        <mxCell id="co2_s" value="«core»" style="text;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;overflow=hidden;rotatable=0;whiteSpace=wrap;html=1;fontSize=10;fontStyle=2;" vertex="1" parent="co2"><mxGeometry y="26" width="300" height="14" as="geometry"/></mxCell>
        <mxCell id="co2_m0" value="AiThrottle (bang ai_throttle)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=6;overflow=hidden;rotatable=0;whiteSpace=wrap;html=1;fontSize=10;fontFamily=Courier New;" vertex="1" parent="co2"><mxGeometry y="40" width="300" height="16" as="geometry"/></mxCell>
        <mxCell id="co2_m1" value="throttle() = upsert atomic Postgres" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=6;overflow=hidden;rotatable=0;whiteSpace=wrap;html=1;fontSize=10;fontFamily=Courier New;" vertex="1" parent="co2"><mxGeometry y="56" width="300" height="16" as="geometry"/></mxCell>
        <mxCell id="co2_m2" value="KHONG dung Redis" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=6;overflow=hidden;rotatable=0;whiteSpace=wrap;html=1;fontSize=10;fontFamily=Courier New;" vertex="1" parent="co2"><mxGeometry y="72" width="300" height="16" as="geometry"/></mxCell>
        <mxCell id="co3" value="core.errors / responses" style="swimlane;fontStyle=1;childLayout=stackLayout;horizontal=1;startSize=26;horizontalStack=0;resizeParent=0;resizeParentMax=0;html=1;whiteSpace=wrap;fontSize=12;swimlaneFillColor=#ffffff;fillColor=#e8e8e8;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="1120" y="1440" width="300" height="62" as="geometry"/></mxCell>
        <mxCell id="co3_s" value="«core»" style="text;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;overflow=hidden;rotatable=0;whiteSpace=wrap;html=1;fontSize=10;fontStyle=2;" vertex="1" parent="co3"><mxGeometry y="26" width="300" height="14" as="geometry"/></mxCell>
        <mxCell id="co3_m0" value="ApplicationError, success_response()" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=6;overflow=hidden;rotatable=0;whiteSpace=wrap;html=1;fontSize=10;fontFamily=Courier New;" vertex="1" parent="co3"><mxGeometry y="40" width="300" height="16" as="geometry"/></mxCell>
        <mxCell id="note" value="Rang buoc kien truc: PostgreSQL la datastore runtime duy nhat. Anti-spam throttle nam trong bang ai_throttle (upsert atomic), nen he thong KHONG dung Redis. Goi y mon duoc cham bang luat tren preference cua participant — KHONG co Vector DB / RAG engine. Job nen duy nhat la run_stale_scan_watchdog; khong co worker queue." style="shape=note;whiteSpace=wrap;html=1;size=14;fontSize=11;align=left;spacingLeft=6;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="1480" y="1440" width="660" height="90" as="geometry"/></mxCell>
