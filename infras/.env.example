# ============================================
#  MenuScan — Biến Môi Trường
#  Copy file này thành .env rồi chỉnh sửa
#  $ cp .env.example .env
# ============================================

# ── Database (PostgreSQL) ──
POSTGRES_DB=menuscan
POSTGRES_USER=menuscan
POSTGRES_PASSWORD=menuscan123
DB_PORT=5432

# ── Backend (FastAPI) ──
BE_PORT=8000
DATABASE_URL=postgresql://menuscan:menuscan123@db:5432/menuscan
STORAGE_PROVIDER=local
STORAGE_LOCAL_ROOT=storage/objects
STORAGE_SIGNED_URL_SECONDS=300

# OCR defaults to a fake provider for local development.
# OCR_PROVIDER=google_vision
# GOOGLE_VISION_API_KEY=replace-me

# LLM parsing defaults to the deterministic rule-based parser.
# Set these after the Gemini project has active billing/credits.
# LLM_PROVIDER=gemini
# LLM_API_KEY=replace-me
# LLM_MODEL=gemini-3.1-flash-lite
# LLM_FALLBACK_MODEL=gemini-2.5-flash
# LLM_TIMEOUT_SECONDS=100
# LLM_MULTIMODAL=true
# LLM_PREALIGN_CSV=true

# S3-compatible object storage for production. Keep buckets private.
# STORAGE_PROVIDER=s3
# STORAGE_BUCKET_NAME=menuscan-sources
# STORAGE_ENDPOINT_URL=https://s3.example.com
# STORAGE_REGION=us-east-1
# STORAGE_ACCESS_KEY_ID=replace-me
# STORAGE_SECRET_ACCESS_KEY=replace-me

# ── Frontend (React/Vite) ──
FE_PORT=5173
VITE_API_URL=http://localhost:8000
