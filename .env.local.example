# ============================================
#  MenuScan — Local Secrets Template
#
#  Copy file này thành .env.local rồi điền giá trị thật:
#    cp .env.local.example .env.local      (bash/WSL)
#    Copy-Item .env.local.example .env.local  (PowerShell)
#
#  docker-compose.yml tự load .env.local nếu tồn tại.
#  File .env.local đã được gitignore — không commit lên repo.
# ============================================

# ── OCR Provider ──
# OCR_API_KEY=

# ── Email Service (Magic Link) ──
# EMAIL_API_KEY=

# ── App Security ──
# SECRET_KEY=         # generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
