# MenuScan local development environment
#
# Copy to env/.env.local:
#   make env ENV=local
#
# This file is safe to commit. Put real secrets only in env/.env.local.

# Docker Compose dev dependencies
POSTGRES_DB=menuscan
POSTGRES_USER=menuscan
POSTGRES_PASSWORD=localdev
DB_PORT=54320
REDIS_PORT=63790

# Backend runtime
DATABASE_URL=postgresql://menuscan:localdev@localhost:54320/menuscan
REDIS_URL=redis://localhost:63790/0
APP_ENV=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173
BACKEND_PORT=8000
RUN_DATABASE_TESTS=1

# Frontend runtime
VITE_API_URL=http://localhost:8000
FRONTEND_PORT=5173

# Optional local secrets
# OCR_API_KEY=
# EMAIL_API_KEY=
# SECRET_KEY=
