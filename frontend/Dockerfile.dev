FROM node:22-alpine

WORKDIR /app

# Copy file cấu hình dependency
COPY package.json package-lock.json ./

# Cài dependencies
RUN npm ci

# Copy source code
COPY . .

# Mở port 5173 (Vite dev server)
EXPOSE 5173

# Chạy Vite dev server, cho phép truy cập từ bên ngoài container
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
