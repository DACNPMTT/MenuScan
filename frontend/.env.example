# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — secrets stay local.

# Google Maps Embed API key — used for the map iframe on the restaurant detail
# page. Get one at https://console.cloud.google.com/google/maps-apis/credentials
# (Maps Embed API must be enabled for the project).
VITE_GOOGLE_MAPS_EMBED_KEY=
